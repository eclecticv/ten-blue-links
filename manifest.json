{
  "manifest_version": 3,
  "name": "Ten Blue Links",
  "version": "0.1.0",
  "description": "Removes AI Overviews, ads, and clutter from Google Search. No settings. Just results.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.google.com/search*",
        "*://www.google.com/?*",
        "*://www.google.com/webhp*"
      ],
      "css": ["hide.css"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
